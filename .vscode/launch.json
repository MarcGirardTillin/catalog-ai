{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug Backend (make backend-start)",
            "type": "debugpy",
            "request": "launch",
            "console": "integratedTerminal",
            "python": "${workspaceFolder}/.venv/bin/python",
            "module": "fastapi",
            "args": [
                "dev",
                "app/main.py",
                "--host",
                "0.0.0.0",
                "--port",
                "8000"
            ],
            "cwd": "${workspaceFolder}/backend",
            "jinja": true,
            "envFile": "${workspaceFolder}/.env"
        },
        {
            "name": "Run Frontend (make frontend-start)",
            "type": "node-terminal",
            "request": "launch",
            "command": "make frontend-start",
            "cwd": "${workspaceFolder}"
        }
    ],
    "compounds": [
        {
            "name": "Run Fullstack (backend + frontend)",
            "configurations": [
                "Debug Backend (make backend-start)",
                "Run Frontend (make frontend-start)"
            ],
            "stopAll": true
        }
    ]
}
