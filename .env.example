# Used by the backend to generate links in emails to the frontend
FRONTEND_HOST=http://localhost:5173

# Environment: local, staging, production
ENVIRONMENT=local

PROJECT_NAME="Full Stack FastAPI Project"
STACK_NAME=full-stack-fastapi-project

# Backend
BACKEND_CORS_ORIGINS="http://localhost,http://localhost:5173,https://localhost,https://localhost:5173"

# Postgres
POSTGRES_SERVER=localhost
POSTGRES_PORT=5432
POSTGRES_DB=app
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changethis

# Auth (app-local users + JWT session cookie)
# Generate a strong secret, e.g. `python -c "import secrets; print(secrets.token_urlsafe(48))"`
APP_SECRET=dev-insecure-secret-change-in-production-please
ACCESS_TOKEN_EXPIRE_MINUTES=11520
AUTH_COOKIE_SECURE=false
# First user, created by `python -m app.initial_data`
FIRST_SUPERUSER=
FIRST_SUPERUSER_PASSWORD=

# Xano (Tillin REST API — read path). Leave empty to disable the integration.
XANO_BASE_URL=
XANO_SERVICE_TOKEN=
XANO_TIMEOUT_SECONDS=30

# Configure these with your own Docker registry images
DOCKER_IMAGE_BACKEND=backend
DOCKER_IMAGE_FRONTEND=frontend
