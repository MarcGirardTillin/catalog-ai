# Production environment for the Scaleway deployment.
# Copy to `.env` ON THE SERVER (never commit the filled-in file) and fill in
# every value. Generate secrets locally; keep credentials in a password
# manager. See docs/deployment-scaleway.md.

ENVIRONMENT=production
PROJECT_NAME=CatalogAI

# --- Domains (sub-domains of tillin.fr) ---
# A DNS A record for each must point at the instance's public IP.
APP_DOMAIN=catalog.tillin.fr
API_DOMAIN=api-catalog.tillin.fr
ACME_EMAIL=ops@tillin.fr

# --- Frontend (baked into config.js at container start) ---
FRONTEND_API_URL=https://api-catalog.tillin.fr
FRONTEND_APP_NAME=Catalog
FRONTEND_MAINTENANCE_ENABLED=false

# --- Backend origin & auth ---
# The API must accept the app origin (credentials mode). List every origin
# that will call the API, comma-separated.
BACKEND_CORS_ORIGINS=https://catalog.tillin.fr
# HTTPS is on in prod, so the session cookie must be Secure.
AUTH_COOKIE_SECURE=true
# Strong random secret: python -c "import secrets; print(secrets.token_urlsafe(48))"
APP_SECRET=CHANGE_ME
ACCESS_TOKEN_EXPIRE_MINUTES=11520
# First admin user, created once by `python -m app.initial_data` (see runbook).
FIRST_SUPERUSER=
FIRST_SUPERUSER_PASSWORD=

# --- Managed PostgreSQL (Scaleway) ---
# Host/port/db/user/password come from the Scaleway database console.
# sslmode=require makes a plaintext downgrade fail loudly (managed DB is
# reached over the public network / private VPC).
POSTGRES_SERVER=CHANGE_ME.pg.fr-par.scw.cloud
POSTGRES_PORT=5432
POSTGRES_DB=catalogai
POSTGRES_USER=CHANGE_ME
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_SSLMODE=require

# --- Xano / Tillin (read + destination) ---
XANO_BASE_URL=
XANO_LOGIN_EMAIL=
XANO_LOGIN_PASSWORD=
XANO_DATA_SOURCE=
XANO_TIMEOUT_SECONDS=30

# --- External services (empty key = integration disabled) ---
ANTHROPIC_API_KEY=
AI_DEFAULT_MODEL=claude-sonnet-5
PHOTOROOM_API_KEY=
FASHN_API_KEY=
FIRECRAWL_API_KEY=

# --- Image names for the built artifacts (built on the host) ---
DOCKER_IMAGE_BACKEND=catalogai-backend
DOCKER_IMAGE_FRONTEND=catalogai-frontend
TAG=latest
